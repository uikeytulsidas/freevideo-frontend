---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';
import { getLangFromUrl } from '../i18n/utils.js';

const {
  title = 'FreeVideo.in — Free Online Video Downloader',
  description = site.description,
  canonical,
} = Astro.props;
const currentUrl = canonical || Astro.url.href;
const lang = getLangFromUrl(Astro.url);
---
<!doctype html>
<html lang={lang}>
  <!-- <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="Astro" />
    <title>{title} | {site.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    <meta property="og:title" content={`${title} | ${site.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
  </head> -->
   <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content="Astro" />

  <title>{title} | {site.name}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />

  <!-- Browser tab favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png?v=2" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/favicon-192x192.png?v=2" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png?v=2" />
  <meta name="theme-color" content="#ffffff" />

  <meta property="og:title" content={`${title} | ${site.name}`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={`${site.url}/assets/freevideo-logo.png`} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ${site.name}`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${site.url}/assets/freevideo-logo.png`} />
</head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
