---
const apiCandidates = JSON.stringify(
  [
    import.meta.env.PUBLIC_API_URL,
    import.meta.env.PUBLIC_RENDER_API_URL,
    import.meta.env.PUBLIC_API_BASE_URL,
    'http://localhost:5000',
  ]
    .filter(Boolean)
    .map((url) => String(url).replace(/\/$/, ''))
);

const { defaultFormat = 'mp4' } = Astro.props;
const isMp3Default = defaultFormat === 'mp3';

const qualities = [
  { value: '240', label: '240p', hint: 'Small file' },
  { value: '360', label: '360p', hint: 'Mobile' },
  { value: '480', label: '480p', hint: 'SD' },
  { value: '720', label: '720p', hint: 'HD' },
  { value: '1080', label: '1080p', hint: 'Full HD' },
  { value: '1440', label: '1440p / 2K', hint: 'Source required' },
  { value: '2160', label: '2160p / 4K', hint: 'Source required' },
  { value: '4320', label: '4320p / 8K', hint: 'Source required' },
];

const audioQualities = [
  { value: '128', label: '128 kbps', hint: 'Small MP3' },
  { value: '192', label: '192 kbps', hint: 'Balanced' },
  { value: '256', label: '256 kbps', hint: 'High quality' },
  { value: '320', label: '320 kbps', hint: 'Best MP3' },
];
---

<section
  class="downloader-card vd-style-downloader"
  id="downloader"
  data-api-candidates={apiCandidates}
>
  <form class="vd-search-card" id="downloadForm">
    <div class="url-line">
      <div class="input-shell input-shell-vd">
        <span class="input-icon">🔗</span>
        <input
          id="videoUrl"
          name="url"
          type="url"
          placeholder="Paste video link here..."
          autocomplete="off"
          required
        />
      </div>

      <button class="btn btn-primary btn-analyze-main" type="submit" id="analyzeBtn">
        <span class="btn-icon">↓</span>
        <span class="btn-label">Analyze Video</span>
      </button>
    </div>

    <div class="detect-wrap detect-wrap-vd">
      <span class="status-dot" id="statusDot"></span>
      <p class="detect-line" id="detectLine">Paste a public video URL to continue.</p>
    </div>

    <div class="vd-options-grid">
      <div class="option-panel format-panel-vd">
        <label>Format</label>
        <div class="segmented segmented-vd">
          <input type="radio" name="format" id="formatMp4" value="mp4" checked={!isMp3Default} />
          <label for="formatMp4">MP4 Video</label>

          <input type="radio" name="format" id="formatMp3" value="mp3" checked={isMp3Default} />
          <label for="formatMp3">MP3 Audio</label>
        </div>
      </div>

      <div class="summary-box selected-summary-box">
        <label>Selected</label>
        <strong id="selectedSummary">{isMp3Default ? 'MP3 • 320 kbps' : 'MP4 • 720p'}</strong>
        <span id="selectedHelp">
          {isMp3Default
            ? 'Choose audio bitrate first, then analyze the video.'
            : 'Choose video resolution first, then analyze the video.'}
        </span>
      </div>
    </div>

    <div class="quality-panel-vd" id="videoQualityPanel" hidden={isMp3Default}>
      <div class="quality-topline-vd">
        <div>
          <label>Choose MP4 resolution</label>
          <p>
            MP4 quality depends on the original video. Higher options such as
            1080p, 2K, 4K or 8K appear only when the source video provides them.
          </p>
        </div>
        <div class="selected-chip" id="selectedChip">
          Selected: {isMp3Default ? 'MP3 • 320 kbps' : 'MP4 • 720p'}
        </div>
      </div>

      <div class="quality-actions choose-only" id="qualityActions" aria-label="Choose video resolution">
        {qualities.map((quality) => (
          <button
            class={`quality-action quality-select-card ${quality.value === '720' ? 'active' : ''}`}
            type="button"
            data-quality={quality.value}
            aria-pressed={quality.value === '720' ? 'true' : 'false'}
          >
            <span class="quality-name">{quality.label}</span>
            <small class="quality-hint">{quality.hint}</small>
            <em class="quality-size" data-size-for={quality.value}>Analyze to show size</em>
            <b data-select-label>{quality.value === '720' ? 'Selected' : 'Select'}</b>
          </button>
        ))}
      </div>
    </div>

    <div class="quality-panel-vd audio-panel-vd" id="audioQualityPanel" hidden={!isMp3Default}>
      <div class="quality-topline-vd">
        <div>
          <label>Choose MP3 audio quality</label>
          <p>
            MP3 is audio-only, so video resolution is not required.
            Choose bitrate such as 128 kbps, 192 kbps, 256 kbps or 320 kbps.
          </p>
        </div>
        <div class="selected-chip" id="audioSelectedChip">
          Selected: {isMp3Default ? 'MP3 • 320 kbps' : 'MP4 • 720p'}
        </div>
      </div>

      <div class="quality-actions choose-only audio-actions-vd" id="audioQualityActions" aria-label="Choose MP3 bitrate">
        {audioQualities.map((quality) => (
          <button
            class={`quality-action audio-quality-select-card ${quality.value === '320' ? 'active' : ''}`}
            type="button"
            data-audio-quality={quality.value}
            aria-pressed={quality.value === '320' ? 'true' : 'false'}
          >
            <span class="quality-name">{quality.label}</span>
            <small class="quality-hint">{quality.hint}</small>
            <em class="quality-size" data-audio-size-for={quality.value}>Analyze to show size</em>
            <b data-select-label>{quality.value === '320' ? 'Selected' : 'Select'}</b>
          </button>
        ))}
      </div>
    </div>

    <p class="privacy-line privacy-line-vd">
      Private, login-only, paid, members-only and DRM-protected videos are not supported.
    </p>
  </form>

  <div class="video-preview-card" id="videoPreview" hidden>
    <div class="preview-thumb" id="previewThumbWrap">
      <img id="previewThumb" alt="Video thumbnail" loading="lazy" decoding="async" hidden />
      <div class="thumb-placeholder" id="thumbFallback">
        <span>▶</span>
        <strong>Preview unavailable</strong>
        <small>Video detected</small>
      </div>
    </div>

    <div class="preview-body">
      <div class="preview-kicker">
        <span id="previewPlatform">Video detected</span>
        <span id="previewDuration">Duration unavailable</span>
        <span id="previewSize">Size unavailable</span>
      </div>

      <h3 id="previewTitle">Video title will appear here</h3>
      <p id="previewMeta">Selected option: {isMp3Default ? 'MP3 • 320 kbps' : 'MP4 • 720p'}</p>

      <div class="preview-actions">
        <button class="btn btn-primary" type="button" id="downloadNowBtn">
          <span>⬇</span>
          <span>Download Now</span>
        </button>
        <button class="btn btn-soft" type="button" id="changeQualityBtn">Change Quality</button>
      </div>
    </div>
  </div>

  <div class="download-state download-state-vd" id="downloadState" hidden>
    <div class="loader-modern" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>

    <div class="state-content">
      <p class="eyebrow" id="statePlatform">Preparing download</p>
      <h3 id="stateTitle">Please keep this tab open.</h3>
      <p id="stateMessage">
        Preparing your selected file. The browser download will start after this step.
      </p>

      <div class="progress-track progress-track-vd">
        <span id="progressFill"></span>
      </div>

      <ol class="prepare-steps prepare-steps-vd" id="prepareSteps">
        <li class="active">Checking video</li>
        <li>Preparing file</li>
        <li>Starting download</li>
      </ol>
    </div>
  </div>
</section>

<script>
  const card = document.querySelector('#downloader');

  let apiCandidates = [];
  try {
    apiCandidates = JSON.parse(card?.getAttribute('data-api-candidates') || '[]');
  } catch {
    apiCandidates = [];
  }

  apiCandidates = apiCandidates
    .filter(Boolean)
    .map((url) => String(url).replace(/\/$/, ''));

  if (!apiCandidates.length) {
    apiCandidates = ['http://localhost:5000'];
  }

  let activeApiBaseUrl = apiCandidates[0];

  function joinApiUrl(baseUrl, path) {
    return `${String(baseUrl).replace(/\/$/, '')}${path.startsWith('/') ? path : `/${path}`}`;
  }

  function isRetryableStatus(status) {
    return [502, 503, 504, 520, 521, 522, 523, 524].includes(status);
  }

  async function apiFetch(path, options = {}) {
    let lastError;

    for (const baseUrl of apiCandidates) {
      try {
        const response = await fetch(joinApiUrl(baseUrl, path), options);

        if (response.ok || !isRetryableStatus(response.status)) {
          activeApiBaseUrl = baseUrl;
          return response;
        }

        lastError = new Error(`API ${baseUrl} returned ${response.status}`);
      } catch (error) {
        lastError = error;
      }
    }

    throw lastError || new Error('Backend is not reachable.');
  }

  const form = document.querySelector('#downloadForm');
  const urlInput = document.querySelector('#videoUrl');
  const detectLine = document.querySelector('#detectLine');
  const statusDot = document.querySelector('#statusDot');

  const qualityButtons = Array.from(document.querySelectorAll('.quality-select-card'));
  const audioQualityButtons = Array.from(document.querySelectorAll('.audio-quality-select-card'));
  const formatRadios = Array.from(document.querySelectorAll('input[name="format"]'));

  const videoQualityPanel = document.querySelector('#videoQualityPanel');
  const audioQualityPanel = document.querySelector('#audioQualityPanel');

  const selectedSummary = document.querySelector('#selectedSummary');
  const selectedChip = document.querySelector('#selectedChip');
  const audioSelectedChip = document.querySelector('#audioSelectedChip');
  const selectedHelp = document.querySelector('#selectedHelp');

  const analyzeBtn = document.querySelector('#analyzeBtn');
  const videoPreview = document.querySelector('#videoPreview');
  const previewThumb = document.querySelector('#previewThumb');
  const thumbFallback = document.querySelector('#thumbFallback');
  const previewPlatform = document.querySelector('#previewPlatform');
  const previewDuration = document.querySelector('#previewDuration');
  const previewSize = document.querySelector('#previewSize');
  const previewTitle = document.querySelector('#previewTitle');
  const previewMeta = document.querySelector('#previewMeta');

  const downloadNowBtn = document.querySelector('#downloadNowBtn');
  const changeQualityBtn = document.querySelector('#changeQualityBtn');

  const downloadState = document.querySelector('#downloadState');
  const statePlatform = document.querySelector('#statePlatform');
  const stateTitle = document.querySelector('#stateTitle');
  const stateMessage = document.querySelector('#stateMessage');
  const progressFill = document.querySelector('#progressFill');
  const prepareSteps = Array.from(document.querySelectorAll('#prepareSteps li'));

  let selectedQuality = '720';
  let selectedAudioQuality = '320';
  let analyzedVideo = null;
  let progressTimer;

  function showThumbnailFallback() {
    previewThumb?.removeAttribute('src');
    if (previewThumb) previewThumb.hidden = true;
    if (thumbFallback) thumbFallback.hidden = false;
    previewThumb?.parentElement?.classList.add('no-thumb');
  }

  function showThumbnail(src) {
    const safeSrc = String(src || '').trim();

    if (!/^https?:\/\//i.test(safeSrc) && !safeSrc.startsWith('data:image/')) {
      showThumbnailFallback();
      return;
    }

    if (previewThumb) {
      previewThumb.hidden = false;
      previewThumb.src = safeSrc;
    }

    if (thumbFallback) thumbFallback.hidden = true;
    previewThumb?.parentElement?.classList.remove('no-thumb');
  }

  function getFormat() {
    return document.querySelector('input[name="format"]:checked')?.value || 'mp4';
  }

  function qualityLabel(value) {
    if (String(value) === '1440') return '1440p / 2K';
    if (String(value) === '2160') return '2160p / 4K';
    if (String(value) === '4320') return '4320p / 8K';
    return `${value}p`;
  }

  function audioQualityLabel(value) {
    return `${value || selectedAudioQuality} kbps`;
  }

  function currentSelectionText() {
    if (getFormat() === 'mp3') {
      return `MP3 • ${audioQualityLabel(selectedAudioQuality)}`;
    }

    return `MP4 • ${qualityLabel(selectedQuality)}`;
  }

  function resetQualitySizes() {
    document.querySelectorAll('[data-size-for]').forEach((item) => {
      item.textContent = 'Analyze to show size';
      item.classList.remove('available', 'unavailable', 'estimated');
    });

    document.querySelectorAll('[data-audio-size-for]').forEach((item) => {
      item.textContent = 'Analyze to show size';
      item.classList.remove('available', 'unavailable', 'estimated');
    });
  }

  function invalidateAnalysis(message) {
    if (!analyzedVideo) return;

    analyzedVideo = null;
    if (videoPreview) videoPreview.hidden = true;
    if (downloadState) downloadState.hidden = true;

    resetQualitySizes();
    setStatus(
      message || 'Selection changed. Analyze the video again to refresh details and size.',
      'idle'
    );
  }

  function updatePanelVisibility() {
    const isMp3 = getFormat() === 'mp3';

    if (videoQualityPanel) videoQualityPanel.hidden = isMp3;
    if (audioQualityPanel) audioQualityPanel.hidden = !isMp3;
  }

  function updateSummary() {
    updatePanelVisibility();

    const text = currentSelectionText();

    if (selectedSummary) selectedSummary.textContent = text;
    if (selectedChip) selectedChip.textContent = `Selected: ${text}`;
    if (audioSelectedChip) audioSelectedChip.textContent = `Selected: ${text}`;
    if (previewMeta) previewMeta.textContent = `Selected option: ${text}`;

    if (selectedHelp) {
      selectedHelp.textContent =
        getFormat() === 'mp3'
          ? analyzedVideo
            ? 'MP3 bitrate selected. Click Download Now to continue.'
            : 'Choose MP3 bitrate first, then analyze the video.'
          : analyzedVideo
            ? 'MP4 resolution selected. Click Download Now to continue.'
            : 'Choose video resolution first, then analyze the video.';
    }
  }

  function updateSizeBadge(item, option) {
    item.classList.remove('available', 'unavailable', 'estimated');

    if (option?.available && option.label && !/unavailable/i.test(option.label)) {
      item.textContent = `${option.label}${option.estimated ? ' est.' : ''}`;
      item.classList.add('available');

      if (option.estimated) item.classList.add('estimated');
    } else {
      item.textContent = option?.message || 'Size unavailable';
      item.classList.add('unavailable');
    }
  }

  function updateQualitySizes(info) {
    const options = Array.isArray(info?.qualitySizes) ? info.qualitySizes : [];
    const map = new Map(options.map((option) => [String(option.quality), option]));

    document.querySelectorAll('[data-size-for]').forEach((item) => {
      const quality = item.getAttribute('data-size-for');
      const option = map.get(String(quality));

      if (!option) {
        updateSizeBadge(item, { available: false, message: 'Not in source' });
        return;
      }

      updateSizeBadge(
        item,
        option.available ? option : { ...option, message: option.message || 'Not in source' }
      );
    });

    const audioOptions = Array.isArray(info?.audioSizes) ? info.audioSizes : [];
    const audioMap = new Map(audioOptions.map((option) => [String(option.bitrate), option]));

    document.querySelectorAll('[data-audio-size-for]').forEach((item) => {
      const bitrate = item.getAttribute('data-audio-size-for');
      const option = audioMap.get(String(bitrate));

      updateSizeBadge(item, option || { available: false, message: 'Size unavailable' });
    });
  }

  function detectPlatform(url) {
    const value = String(url || '').toLowerCase();

    if (value.includes('youtube.com') || value.includes('youtu.be')) return 'YouTube';
    if (value.includes('instagram.com')) return 'Instagram';
    if (value.includes('facebook.com') || value.includes('fb.watch')) return 'Facebook';
    if (value.includes('twitter.com') || value.includes('x.com')) return 'Twitter/X';
    if (value.includes('dailymotion.com') || value.includes('dai.ly')) return 'Dailymotion';
    if (value.includes('reddit.com') || value.includes('redd.it')) return 'Reddit';
    if (value.trim().length > 8) return 'Supported public website';

    return 'Paste a public video URL to continue.';
  }

  function setStatus(message, type = 'idle') {
    if (detectLine) detectLine.textContent = message;
    statusDot?.setAttribute('data-status', type);
  }

  function getFriendlyNetworkError(error, fallbackMessage) {
    const message = String(error?.message || '');

    if (error?.name === 'TypeError' || message.includes('Failed to fetch')) {
      return 'Backend is not reachable. Please check your connection and try again.';
    }

    return error?.message || fallbackMessage;
  }

  async function readApiError(response, fallbackMessage) {
    try {
      const data = await response.json();
      return data?.message || data?.error || fallbackMessage;
    } catch {
      return fallbackMessage;
    }
  }

  function setControlsDisabled(disabled) {
    if (analyzeBtn) analyzeBtn.disabled = disabled;
    if (downloadNowBtn) downloadNowBtn.disabled = disabled;

    qualityButtons.forEach((button) => {
      button.disabled = disabled;
    });

    audioQualityButtons.forEach((button) => {
      button.disabled = disabled;
    });

    formatRadios.forEach((radio) => {
      radio.disabled = disabled;
    });
  }

  function resetSteps() {
    prepareSteps.forEach((step, index) => {
      step.classList.toggle('active', index === 0);
      step.classList.remove('done');
    });
  }

  function activateStep(index) {
    prepareSteps.forEach((step, stepIndex) => {
      step.classList.toggle('active', stepIndex === index);
      step.classList.toggle('done', stepIndex < index);
    });
  }

  function setAnalyzing(isAnalyzing) {
    if (!analyzeBtn) return;

    analyzeBtn.disabled = isAnalyzing;

    const icon = analyzeBtn.querySelector('.btn-icon');
    const label = analyzeBtn.querySelector('.btn-label');

    if (icon) icon.textContent = isAnalyzing ? '⏳' : '↓';
    if (label) label.textContent = isAnalyzing ? 'Analyzing...' : 'Analyze Video';
  }

  function showPreview(info) {
    analyzedVideo = info;

    if (previewPlatform) previewPlatform.textContent = info.platform || detectPlatform(urlInput?.value);
    if (previewDuration) previewDuration.textContent = info.duration || 'Duration unavailable';

    if (previewSize) {
      previewSize.textContent = info.fileSize
        ? `Size: ${info.fileSize}${info.fileSizeEstimated ? ' (est.)' : ''}`
        : 'Size unavailable';
    }

    if (previewTitle) previewTitle.textContent = info.title || 'Video title will appear here';

    const analyzedOption = info.selectedQualityTag
      ? `${getFormat().toUpperCase()} • ${info.selectedQualityTag}`
      : currentSelectionText();

    if (previewMeta) previewMeta.textContent = `Selected option: ${analyzedOption}`;

    updateQualitySizes(info);

    if (info.thumbnail) {
      showThumbnail(info.thumbnail);
    } else {
      showThumbnailFallback();
    }

    if (videoPreview) videoPreview.hidden = false;
    if (downloadState) downloadState.hidden = true;

    const successMessage =
      getFormat() === 'mp3'
        ? 'Audio analyzed successfully. Review MP3 bitrate sizes, then click Download Now.'
        : 'Video analyzed successfully. Review available size for each resolution, then click Download Now.';

    setStatus(successMessage, 'success');

    videoPreview?.scrollIntoView({ behavior: 'smooth', block: 'center' });

    updateSummary();
  }

  async function analyzeVideo() {
    const url = urlInput?.value.trim();

    if (!url) {
      urlInput?.focus();
      setStatus('Please paste a video URL first.', 'error');
      return;
    }

    setStatus(
      `Analyzing ${detectPlatform(url)} ${getFormat() === 'mp3' ? 'audio' : 'video'}...`,
      'loading'
    );

    setAnalyzing(true);

    if (videoPreview) videoPreview.hidden = true;
    if (downloadState) downloadState.hidden = true;

    analyzedVideo = null;
    resetQualitySizes();

    try {
      const response = await apiFetch('/api/info', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          url,
          format: getFormat(),
          quality: selectedQuality,
          audioQuality: selectedAudioQuality,
        }),
      });

      if (!response.ok) {
        const message = await readApiError(response, 'Could not analyze this video.');
        throw new Error(message);
      }

      const data = await response.json();
      showPreview(data);
    } catch (error) {
      setStatus(
        getFriendlyNetworkError(error, 'Video analysis failed. Check backend terminal.'),
        'error'
      );
    } finally {
      setAnalyzing(false);
    }
  }

  function startPreparingState(payload) {
    clearInterval(progressTimer);
    resetSteps();

    if (downloadState) downloadState.hidden = false;

    if (statePlatform) statePlatform.textContent = `${detectPlatform(payload.url)} download`;

    if (stateTitle) {
      stateTitle.textContent =
        payload.format === 'mp3'
          ? `Preparing MP3 • ${audioQualityLabel(payload.audioQuality)}`
          : `Preparing MP4 • ${qualityLabel(payload.quality)}`;
    }

    if (stateMessage) {
      stateMessage.textContent =
        'Please keep this tab open. The browser download will start automatically after preparation.';
    }

    if (progressFill) progressFill.style.width = '10%';

    let progress = 10;

    progressTimer = setInterval(() => {
      progress = Math.min(progress + Math.random() * 8 + 3, 90);

      if (progressFill) progressFill.style.width = `${progress}%`;
      if (progress > 35) activateStep(1);
      if (progress > 72) activateStep(2);
    }, 620);

    downloadState?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function buildDownloadUrl(downloadUrl) {
    if (!downloadUrl) return '';
    if (/^https?:\/\//i.test(downloadUrl)) return downloadUrl;

    return `${activeApiBaseUrl}${downloadUrl.startsWith('/') ? '' : '/'}${downloadUrl}`;
  }

  function finishPreparingState(downloadUrl, filename) {
    clearInterval(progressTimer);

    activateStep(2);

    if (progressFill) progressFill.style.width = '100%';
    if (stateTitle) stateTitle.textContent = 'Download is ready';

    const finalUrl = buildDownloadUrl(downloadUrl);
    const safeName = filename || (getFormat() === 'mp3' ? 'audio.mp3' : 'video.mp4');

    if (stateMessage) {
      stateMessage.innerHTML = '';

      const messageText = document.createTextNode(
        'Your browser download has started. Check the Downloads section in Chrome or your browser. '
      );

      const manualLink = document.createElement('a');
      manualLink.href = finalUrl;
      manualLink.download = safeName;
      manualLink.textContent = 'Click here if it does not start.';
      manualLink.rel = 'noopener';

      stateMessage.appendChild(messageText);
      stateMessage.appendChild(manualLink);
    }

    const link = document.createElement('a');
    link.href = finalUrl;
    link.download = safeName;
    link.rel = 'noopener';
    link.style.display = 'none';

    document.body.appendChild(link);
    link.click();
    link.remove();
  }

  function showDownloadError(message) {
    clearInterval(progressTimer);

    if (downloadState) downloadState.hidden = false;
    if (progressFill) progressFill.style.width = '0%';
    if (statePlatform) statePlatform.textContent = 'Download failed';
    if (stateTitle) stateTitle.textContent = 'Could not prepare this file';
    if (stateMessage) stateMessage.textContent = message;

    prepareSteps.forEach((step) => {
      step.classList.remove('active', 'done');
    });
  }

  async function prepareDownload() {
    const payload = {
      url: urlInput?.value.trim(),
      format: getFormat(),
      quality: selectedQuality,
      audioQuality: selectedAudioQuality,
    };

    if (!payload.url) {
      urlInput?.focus();
      setStatus('Please paste a video URL first.', 'error');
      return;
    }

    if (!analyzedVideo) {
      setStatus('Analyze the video first, then click Download Now.', 'error');
      await analyzeVideo();
      return;
    }

    updateSummary();
    startPreparingState(payload);
    setControlsDisabled(true);

    const downloadLabel = downloadNowBtn?.querySelector('span:last-child');
    if (downloadLabel) downloadLabel.textContent = 'Preparing...';

    try {
      const response = await apiFetch('/api/download', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        const message = await readApiError(response, 'Could not prepare download.');
        throw new Error(message);
      }

      const data = await response.json();

      if (!data.downloadUrl) {
        throw new Error('Backend prepared the file but did not return a download URL.');
      }

      finishPreparingState(data.downloadUrl, data.filename);
    } catch (error) {
      showDownloadError(
        getFriendlyNetworkError(error, 'Download failed. Check backend terminal for details.')
      );
    } finally {
      setControlsDisabled(false);

      if (downloadLabel) downloadLabel.textContent = 'Download Now';
    }
  }

  urlInput?.addEventListener('input', () => {
    analyzedVideo = null;

    if (videoPreview) videoPreview.hidden = true;

    resetQualitySizes();
    setStatus(detectPlatform(urlInput.value), 'idle');
  });

  formatRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      invalidateAnalysis('Format changed. Analyze again to refresh file size.');
      updateSummary();

      const isMp3 = getFormat() === 'mp3';

      setStatus(
        isMp3
          ? 'MP3 selected. Choose bitrate, then analyze to show audio size.'
          : 'MP4 selected. Choose resolution, then analyze to show video size.',
        'success'
      );
    });
  });

  qualityButtons.forEach((button) => {
    button.addEventListener('click', () => {
      selectedQuality = button.dataset.quality || '720';

      qualityButtons.forEach((item) => {
        const isActive = item === button;

        item.classList.toggle('active', isActive);
        item.setAttribute('aria-pressed', isActive ? 'true' : 'false');

        const badge = item.querySelector('b');
        if (badge) badge.textContent = isActive ? 'Selected' : 'Select';
      });

      invalidateAnalysis('Resolution changed. Analyze the video again to refresh file size.');
      updateSummary();
      setStatus(`Selected ${qualityLabel(selectedQuality)}. Analyze the video to show the size.`, 'success');
    });
  });

  audioQualityButtons.forEach((button) => {
    button.addEventListener('click', () => {
      selectedAudioQuality = button.dataset.audioQuality || '320';

      audioQualityButtons.forEach((item) => {
        const isActive = item === button;

        item.classList.toggle('active', isActive);
        item.setAttribute('aria-pressed', isActive ? 'true' : 'false');

        const badge = item.querySelector('b');
        if (badge) badge.textContent = isActive ? 'Selected' : 'Select';
      });

      invalidateAnalysis('MP3 bitrate changed. Analyze again to refresh audio size.');
      updateSummary();
      setStatus(`Selected MP3 ${audioQualityLabel(selectedAudioQuality)}. Analyze to show the size.`, 'success');
    });
  });

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    analyzeVideo();
  });

  downloadNowBtn?.addEventListener('click', prepareDownload);

  changeQualityBtn?.addEventListener('click', () => {
    const target = getFormat() === 'mp3' ? '#audioQualityPanel' : '#qualityActions';
    document.querySelector(target)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  previewThumb?.addEventListener('error', showThumbnailFallback);

  updateSummary();
  resetQualitySizes();
</script>