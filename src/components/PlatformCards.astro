---
import { platforms } from '../data/site.js';
const { exclude = '' } = Astro.props;
const list = platforms.filter((platform) => platform.slug !== exclude);
---
<section class="section-pad" id="platforms">
  <div class="container section-head">
    <p class="eyebrow">Supported platforms</p>
    <h2>One downloader for every major site</h2>
    <p>Pick a platform to start downloading public videos in MP4 or MP3 — fast, free and private.</p>
  </div>
  <div class="container platform-grid">
    {list.map((platform) => (
      <a href={platform.slug} class="platform-card card-hover">
        <span class={`platform-icon ${platform.color}`}>{platform.icon}</span>
        <span>
          <strong>{platform.name}</strong>
          <small>{platform.tagline}</small>
        </span>
        <span class="arrow">→</span>
      </a>
    ))}
  </div>
</section>
