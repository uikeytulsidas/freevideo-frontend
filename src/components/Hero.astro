---
import DownloaderForm from './DownloaderForm.astro';
const {
  eyebrow = 'Free online tool',
  title = 'FreeVideo.in Video Downloader',
  description = 'FreeVideo.in helps you download public videos as MP4 or MP3. Paste a link, choose format and quality, analyze the video, then save it to your device.',
  badges = [],
  defaultFormat = 'mp4',
} = Astro.props;
---
<section class="hero section-pad">
  <div class="container hero-center">
    <p class="eyebrow" data-i18n="hero.eyebrow">{eyebrow}</p>
    <h1 data-i18n="hero.title">{title}</h1>
    <p class="hero-desc" data-i18n="hero.description">{description}</p>
    <DownloaderForm defaultFormat={defaultFormat} />
    <p class="terms-line" data-i18n="hero.terms">By using this service, you agree to use it only for videos you own or have permission to download.</p>
    {badges.length > 0 && (
      <div class="hero-tags">
        {badges.map((badge) => <span>{badge}</span>)}
      </div>
    )}
  </div>
</section>
